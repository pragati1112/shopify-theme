<section class="trending-products">
  <div class="page-width">

    <div class="trending-header">
      <h2>🔥 Trending Right Now</h2>

      <div class="trending-tabs">
        <button class="active">All</button>
        <button>This Week</button>
        <button>New Arrivals</button>
        <button>Best Sellers</button>
      </div>
    </div>

    <div class="trending-grid">

      {% for product in collections[section.settings.collection].products limit: 5 %}
        
        <div class="product-card">

          <a href="{{ product.url }}" class="product-image">
            <img
              src="{{ product.featured_image | image_url: width: 600 }}"
              alt="{{ product.title }}"
              loading="lazy"
            >
          </a>

          {% if product.tags contains 'Hot' %}
            <span class="product-badge hot">🔥 Hot</span>
          {% endif %}

          {% if product.tags contains 'New' %}
            <span class="product-badge new">New</span>
          {% endif %}

          <div class="product-info">
            <h3>{{ product.title }}</h3>

            <div class="price-wrapper">
              <span class="sale-price">
                {{ product.price | money }}
              </span>

              {% if product.compare_at_price > product.price %}
                <span class="compare-price">
                  {{ product.compare_at_price | money }}
                </span>
              {% endif %}
            </div>
          </div>

        </div>

      {% endfor %}

    </div>

  </div>
</section>

<style>

.trending-products{
  padding:70px 0;
  background:#f7f7f7;
}

.trending-header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:40px;
  gap:20px;
  flex-wrap:wrap;
}

.trending-header h2{
  font-size:38px;
  margin:0;
  font-weight:700;
  color:#1d1d1d;
}

.trending-tabs{
  display:flex;
  gap:12px;
  flex-wrap:wrap;
}

.trending-tabs button{
  border:none;
  padding:10px 18px;
  border-radius:999px;
  background:#ececec;
  cursor:pointer;
  font-size:14px;
  transition:0.3s;
}

.trending-tabs button.active{
  background:#ff6a3d;
  color:#fff;
}

.trending-grid{
  display:grid;
  grid-template-columns:repeat(5,1fr);
  gap:24px;
}

.product-card{
  position:relative;
}

.product-image{
  display:block;
  background:#efe7e4;
  border-radius:16px;
  overflow:hidden;
  aspect-ratio:1/1;
  padding:30px;
}

.product-image img{
  width:100%;
  height:100%;
  object-fit:contain;
  transition:0.4s ease;
}

.product-card:hover img{
  transform:scale(1.06);
}

.product-badge{
  position:absolute;
  top:12px;
  left:12px;
  font-size:12px;
  padding:5px 10px;
  border-radius:999px;
  color:#fff;
  font-weight:600;
}

.product-badge.hot{
  background:#ff6a3d;
}

.product-badge.new{
  background:#4f7cff;
}

.product-info{
  margin-top:14px;
}

.product-info h3{
  font-size:16px;
  margin:0 0 8px;
  color:#1d1d1d;
}

.price-wrapper{
  display:flex;
  align-items:center;
  gap:8px;
  flex-wrap:wrap;
}

.sale-price{
  color:#ff5a36;
  font-weight:700;
  font-size:15px;
}

.compare-price{
  color:#9b9b9b;
  text-decoration:line-through;
  font-size:13px;
}

@media(max-width:1100px){
  .trending-grid{
    grid-template-columns:repeat(3,1fr);
  }
}

@media(max-width:768px){

  .trending-header h2{
    font-size:28px;
  }

  .trending-grid{
    grid-template-columns:repeat(2,1fr);
    gap:18px;
  }

  .product-image{
    padding:20px;
  }
}

@media(max-width:520px){

  .trending-grid{
    grid-template-columns:1fr;
  }

}
</style>

{% schema %}
{
  "name": "Trending Products",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    }
  ],
  "presets": [
    {
      "name": "Trending Products"
    }
  ]
}
{% endschema %}